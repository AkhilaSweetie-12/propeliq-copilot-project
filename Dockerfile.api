# Multi-stage build for ASP.NET Core API
# Usage: docker build -f src/api/Dockerfile -t propeliq-api .

FROM mcr.microsoft.com/dotnet/sdk:9.0 AS builder

WORKDIR /src

# Copy project files
COPY ["src/api/*.csproj", "src/api/"]
COPY ["src/domain/*.csproj", "src/domain/"]
COPY ["src/infrastructure/*.csproj", "src/infrastructure/"]

# Restore dependencies
RUN dotnet restore "src/api/PropelIQ.Api.csproj"

# Copy source code
COPY . .

# Build and publish
RUN dotnet publish "src/api/PropelIQ.Api.csproj" \
    -c Release \
    -o /app/publish \
    --no-restore

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:9.0

WORKDIR /app

# Install migration tools
RUN dotnet tool install -g dotnet-ef
ENV PATH="${PATH}:/root/.dotnet/tools"

# Copy published app
COPY --from=builder /app/publish .

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD dotnet-ef --version && curl -f http://localhost:5000/health || exit 1

EXPOSE 5000

ENTRYPOINT ["dotnet", "PropelIQ.Api.dll"]
